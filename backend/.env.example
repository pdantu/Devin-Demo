# Devin Service User API Key (starts with cog_)
# Create at: Settings > Service Users > Generate API Key
DEVIN_API_KEY=cog_your_key_here

# Devin Organization ID (starts with org-)
# Found at: Settings > Service Users page
DEVIN_ORG_ID=org_your_org_id_here

# GitHub repo in owner/repo format (your fork of superset)
GITHUB_REPO=your_org/superset

# GitHub Personal Access Token (repo scope needed to read issues)
GITHUB_TOKEN=ghp_your_token_here
WEBHOOK_SECRET=your_webhook_secret_here

# Devin Knowledge Note ID — Superset codebase context (loaded into every session)
KNOWLEDGE_ID_SUPERSET=note-3f76ca47d13c4a24be00a02ca2ba305e

# Devin Playbook IDs (optional — create playbooks in Devin UI)
# Leave blank to skip playbook assignment
PLAYBOOK_ID_SECURITY=playbook_id_here
PLAYBOOK_ID_TECH_DEBT=playbook_id_here